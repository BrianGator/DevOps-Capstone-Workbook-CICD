# GEMINI_API_KEY: Required for Gemini AI API calls.
# Automatically injected at runtime from secure secrets configuration.
# Users configure this via the Secrets panel in the dev workspace UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this workbook is hosted.
# Automatically injected at runtime with the live host URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

